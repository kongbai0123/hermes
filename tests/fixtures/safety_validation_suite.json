    "id": "TC-BACKOFF-001",
    "name": "BACKOFF_trigger_stop",
    "description": "連續失敗兩次應觸發 TOOL_FAILURE_BACKOFF，停止執行迴圈",
    "autonomy_level": "L2",
    "tool": "autonomous_loop",
    "params": {
      "tasks": [
        {"tool": "read_file", "success": false},
        {"tool": "write_file", "success": false}
      ]
    },
    "expected_outcome": "FAILED",
    "expected_trace": "TOOL_FAILURE_BACKOFF"
  },
  {
    "id": "TC-BACKOFF-002",
    "name": "BACKOFF_reset_on_success",
    "description": "失敗後若出現成功操作，應重置計數，不觸發 Backoff",
    "autonomy_level": "L2",
    "tool": "autonomous_loop",
    "params": {
      "tasks": [
        {"tool": "read_file", "success": false},
        {"tool": "read_file", "success": true},
        {"tool": "write_file", "success": false}
      ]
    },
    "expected_outcome": "COMPLETED",
    "expected_trace": "LOOP_COMPLETED"
  },
